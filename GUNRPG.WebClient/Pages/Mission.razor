@page "/missions/{MissionId:guid}"
@inject AuthService Auth
@inject NavigationManager Nav
@inject MissionService MissionSvc
@inject NodeConnectionService NodeService
@inject IJSRuntime JS
@implements IAsyncDisposable

<FluentStack Orientation="Orientation.Vertical" Style="gap: 1rem; max-width: 900px; margin: 0 auto;">
    <FluentStack Orientation="Orientation.Horizontal" Style="align-items: center; gap: 0.5rem;">
        <FluentButton Appearance="Appearance.Outline" OnClick="GoBack">
            ← Back
        </FluentButton>
        <h2 style="margin: 0;">Mission — Turn @(_session?.TurnNumber ?? 0)</h2>
    </FluentStack>

    @if (!string.IsNullOrEmpty(_error))
    {
        <FluentMessageBar Title="Error" Intent="MessageIntent.Error">@_error</FluentMessageBar>
    }

    @if (_loading)
    {
        <FluentProgressRing />
    }
    else if (_session is not null)
    {
        @if (_session.IsConcluded)
        {
            <FluentMessageBar Title="@(_session.IsVictory ? "Victory!" : "Defeat")"
                              Intent="@(_session.IsVictory ? MessageIntent.Success : MessageIntent.Error)">
                @(_session.IsVictory ? "You defeated the enemy! Exfil to secure your XP." : "You were defeated. The mission has failed.")
            </FluentMessageBar>
        }

        <FluentStack Orientation="Orientation.Horizontal" Style="gap: 1rem; flex-wrap: wrap; width: 100%;">
            <FluentCard Style="flex: 1; min-width: 200px;">
                <FluentLabel Typo="Typography.H5">Player</FluentLabel>
                <FluentStack Orientation="Orientation.Vertical" Style="gap: 0.25rem; margin-top: 0.5rem;">
                    <div><strong>@_session.Player.Name</strong></div>
                    <div>HP: @_session.Player.Health.ToString("F0") / @_session.Player.MaxHealth.ToString("F0")</div>
                    <div>Stamina: @_session.Player.Stamina.ToString("F0")</div>
                    <div>Ammo: @_session.Player.CurrentAmmo @(_session.Player.MagazineSize.HasValue ? $"/ {_session.Player.MagazineSize}" : "")</div>
                    <div>Distance: @_session.Player.DistanceToOpponent.ToString("F0")m</div>
                    <div>Cover: @(string.IsNullOrEmpty(_session.Player.CurrentCover) || _session.Player.CurrentCover == "None" ? "None" : _session.Player.CurrentCover)</div>
                    <div>Aim: @_session.Player.AimState | Move: @_session.Player.MovementState</div>
                    @if (_session.Player.IsSuppressed)
                    {
                        <FluentBadge Appearance="Appearance.Neutral">Suppressed</FluentBadge>
                    }
                </FluentStack>
            </FluentCard>

            <FluentCard Style="flex: 1; min-width: 200px;">
                <FluentLabel Typo="Typography.H5">Enemy (Lv @_session.EnemyLevel)</FluentLabel>
                <FluentStack Orientation="Orientation.Vertical" Style="gap: 0.25rem; margin-top: 0.5rem;">
                    <div><strong>@_session.Enemy.Name</strong></div>
                    <div>HP: @_session.Enemy.Health.ToString("F0") / @_session.Enemy.MaxHealth.ToString("F0")</div>
                    <div>Distance: @_session.Enemy.DistanceToOpponent.ToString("F0")m</div>
                    <div>Cover: @(string.IsNullOrEmpty(_session.Enemy.CurrentCover) || _session.Enemy.CurrentCover == "None" ? "None" : _session.Enemy.CurrentCover)</div>
                    @if (!_session.Enemy.IsAlive)
                    {
                        <FluentBadge Appearance="Appearance.Neutral">Defeated</FluentBadge>
                    }
                </FluentStack>
            </FluentCard>
        </FluentStack>

        @if (!_session.IsConcluded)
        {
            <FluentCard Style="overflow: visible;">
                <FluentLabel Typo="Typography.H5">Actions</FluentLabel>
                <FluentStack Orientation="Orientation.Vertical" Style="gap: 0.75rem; margin-top: 0.5rem;">
                    <FluentStack Orientation="Orientation.Horizontal" Style="gap: 1rem; flex-wrap: wrap;">
                        <div Style="flex: 1; min-width: 150px;">
                            <FluentLabel>🎯 Primary</FluentLabel>
                            <FluentSelect TOption="string" @bind-Value="_primary" Style="width: 100%;" Disabled="_busy">
                                <FluentOption TOption="string" Value="None">None</FluentOption>
                                <FluentOption TOption="string" Value="Fire" Disabled="@(_session.Player.CurrentAmmo <= 0)">
                                    Fire @(_session.Player.CurrentAmmo <= 0 ? "(no ammo)" : "")
                                </FluentOption>
                                <FluentOption TOption="string" Value="Reload" Disabled="@(_session.Player.MagazineSize.HasValue && _session.Player.CurrentAmmo >= _session.Player.MagazineSize)">
                                    Reload @((_session.Player.MagazineSize.HasValue && _session.Player.CurrentAmmo >= _session.Player.MagazineSize) ? "(full)" : "")
                                </FluentOption>
                            </FluentSelect>
                        </div>

                        <div Style="flex: 1; min-width: 150px;">
                            <FluentLabel>🏃 Movement</FluentLabel>
                            <FluentSelect TOption="string" @bind-Value="_movement" Style="width: 100%;" Disabled="_busy">
                                <FluentOption TOption="string" Value="Stand">Stand</FluentOption>
                                <FluentOption TOption="string" Value="WalkToward">Walk Toward</FluentOption>
                                <FluentOption TOption="string" Value="WalkAway">Walk Away</FluentOption>
                                <FluentOption TOption="string" Value="SprintToward" Disabled="@(_session.Player.Stamina <= 0)">
                                    Sprint Toward @(_session.Player.Stamina <= 0 ? "(no stamina)" : "")
                                </FluentOption>
                                <FluentOption TOption="string" Value="SprintAway" Disabled="@(_session.Player.Stamina <= 0)">
                                    Sprint Away @(_session.Player.Stamina <= 0 ? "(no stamina)" : "")
                                </FluentOption>
                                <FluentOption TOption="string" Value="SlideToward" Disabled="@(_session.Player.Stamina < 30)">
                                    Slide Toward @(_session.Player.Stamina < 30 ? "(need 30 stamina)" : "")
                                </FluentOption>
                                <FluentOption TOption="string" Value="SlideAway" Disabled="@(_session.Player.Stamina < 30)">
                                    Slide Away @(_session.Player.Stamina < 30 ? "(need 30 stamina)" : "")
                                </FluentOption>
                                <FluentOption TOption="string" Value="Crouch">Crouch</FluentOption>
                            </FluentSelect>
                        </div>

                        <div Style="flex: 1; min-width: 150px;">
                            <FluentLabel>🧍 Stance</FluentLabel>
                            <FluentSelect TOption="string" @bind-Value="_stance" Style="width: 100%;" Disabled="_busy">
                                <FluentOption TOption="string" Value="None">None</FluentOption>
                                <FluentOption TOption="string" Value="EnterADS" Disabled="@(_session.Player.AimState == "ADS" || _session.Player.MovementState == "Sliding")">
                                    Enter ADS @((_session.Player.AimState == "ADS" || _session.Player.MovementState == "Sliding") ? "(unavailable)" : "")
                                </FluentOption>
                                <FluentOption TOption="string" Value="ExitADS" Disabled="@(_session.Player.AimState == "Hip")">
                                    Exit ADS @(_session.Player.AimState == "Hip" ? "(already hip)" : "")
                                </FluentOption>
                            </FluentSelect>
                        </div>

                        <div Style="flex: 1; min-width: 150px;">
                            <FluentLabel>🏠 Cover</FluentLabel>
                            <FluentSelect TOption="string" @bind-Value="_cover" Style="width: 100%;" Disabled="_busy">
                                <FluentOption TOption="string" Value="None">None</FluentOption>
                                <FluentOption TOption="string" Value="EnterPartial" Disabled="@EnterCoverDisabled">
                                    Enter Partial @(EnterCoverDisabled ? "(unavailable)" : "")
                                </FluentOption>
                                <FluentOption TOption="string" Value="EnterFull" Disabled="@EnterCoverDisabled">
                                    Enter Full @(EnterCoverDisabled ? "(unavailable)" : "")
                                </FluentOption>
                                <FluentOption TOption="string" Value="Exit" Disabled="@(_session.Player.CurrentCover == "None" || string.IsNullOrEmpty(_session.Player.CurrentCover))">
                                    Exit Cover @((_session.Player.CurrentCover == "None" || string.IsNullOrEmpty(_session.Player.CurrentCover)) ? "(not in cover)" : "")
                                </FluentOption>
                            </FluentSelect>
                        </div>
                    </FluentStack>

                    <FluentStack Orientation="Orientation.Horizontal" Style="gap: 0.5rem; align-items: center;">
                        <FluentButton Appearance="Appearance.Accent"
                                      OnClick="TakeTurnAsync"
                                      Disabled="_busy">
                            @(_busy ? "Submitting..." : "⚡ Submit & Advance Turn")
                        </FluentButton>
                        <span style="font-size: 0.8rem; color: var(--neutral-foreground-hint);">
                            Primary: @_primary | Movement: @_movement | Stance: @_stance | Cover: @_cover
                        </span>
                    </FluentStack>
                </FluentStack>
            </FluentCard>
        }
        else
        {
            <FluentStack Orientation="Orientation.Horizontal" Style="gap: 0.5rem; flex-wrap: wrap;">
                <FluentButton Appearance="Appearance.Outline" OnClick="GoBack">
                    Back to Infiltration
                </FluentButton>
            </FluentStack>
        }

        @if (_session.BattleLog.Count > 0)
        {
            <FluentCard>
                <FluentLabel Typo="Typography.H5">Battle Log</FluentLabel>
                <FluentStack Orientation="Orientation.Vertical" Style="gap: 0.125rem; margin-top: 0.5rem; max-height: 300px; overflow-y: auto;">
                    @foreach (var entry in _session.BattleLog.OrderByDescending(e => e.TimeMs))
                    {
                        <div style="font-size: 0.85rem; padding: 0.1rem 0;">
                            <span style="color: var(--neutral-foreground-hint);">[@entry.TimeMs ms]</span>
                            @if (!string.IsNullOrEmpty(entry.ActorName))
                            {
                                <strong> @entry.ActorName:</strong>
                            }
                            @entry.Message
                        </div>
                    }
                </FluentStack>
            </FluentCard>
        }
    }
</FluentStack>

@code {
    [Parameter] public Guid MissionId { get; set; }

    private CombatSession? _session;
    private bool _loading = true;
    private bool _busy;
    private string? _error;

    // Intent selections (default to no-op values)
    private string _primary = "None";
    private string _movement = "Stand";
    private string _stance = "None";
    private string _cover = "None";

    // SSE
    private DotNetObjectReference<Mission>? _dotNetRef;
    private string? _sseUrl;

    private bool EnterCoverDisabled => _session is not null &&
        (_session.Player.CurrentCover != "None" && !string.IsNullOrEmpty(_session.Player.CurrentCover)
         || (_session.Player.MovementState != "Stationary"
             && _session.Player.MovementState != "Idle"
             && _session.Player.MovementState != "Crouching"));

    protected override async Task OnInitializedAsync()
    {
        if (!Auth.IsAuthenticated)
        {
            Nav.NavigateTo("login");
            return;
        }

        await LoadAsync();

        // Start SSE stream for real-time sync
        await StartSseAsync();
    }

    private async Task StartSseAsync()
    {
        if (_session is null || _session.IsConcluded)
            return;

        var baseUrl = await NodeService.GetBaseUrlAsync();
        if (string.IsNullOrEmpty(baseUrl))
            return;

        _sseUrl = $"{baseUrl}/sessions/{MissionId}/stream";
        _dotNetRef = DotNetObjectReference.Create(this);
        await JS.InvokeVoidAsync("sseHelper.connect", _sseUrl, _dotNetRef, nameof(OnSessionUpdated));
    }

    [JSInvokable]
    public async Task OnSessionUpdated()
    {
        await SilentRefreshAsync();

        if (_session?.IsConcluded == true)
            await StopSseAsync();

        await InvokeAsync(StateHasChanged);
    }

    /// <summary>
    /// Re-fetches the session state without toggling _loading to avoid UI flicker during SSE updates.
    /// </summary>
    private async Task SilentRefreshAsync()
    {
        var (data, error) = await MissionSvc.GetStateAsync(MissionId);
        if (data is not null)
        {
            _session = data;
            _error = null;
        }
        else if (error is not null)
        {
            _error = error;
        }
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;
        StateHasChanged();

        var (data, error) = await MissionSvc.GetStateAsync(MissionId);
        _session = data;
        _error = error;
        _loading = false;
    }

    private async Task TakeTurnAsync()
    {
        if (_session is null) return;

        _error = null;
        _busy = true;
        StateHasChanged();

        var operatorId = _session.OperatorId;
        var selectedPrimary = _primary == "None" ? null : _primary;
        var selectedMovement = _movement;
        var selectedStance = _stance == "None" ? null : _stance;
        var selectedCover = _cover == "None" ? null : _cover;

        var (intentResult, intentError) = await MissionSvc.SubmitIntentAsync(MissionId, operatorId, selectedPrimary, selectedMovement, selectedStance, selectedCover);
        if (intentError is not null)
        {
            _error = intentError;
            _busy = false;
            StateHasChanged();
            return;
        }

        var (advanceResult, advanceError) = await MissionSvc.AdvanceAsync(MissionId, operatorId);
        _busy = false;

        if (advanceError is not null)
        {
            _error = advanceError;
            _session = intentResult ?? _session;
            StateHasChanged();
            return;
        }

        _session = advanceResult ?? _session;
        StateHasChanged();
    }

    private async Task StopSseAsync()
    {
        if (!string.IsNullOrEmpty(_sseUrl))
        {
            try
            {
                await JS.InvokeVoidAsync("sseHelper.disconnect", _sseUrl);
            }
            catch
            {
                // Ignore JS interop errors during cleanup
            }
        }

        _sseUrl = null;

        if (_dotNetRef is not null)
        {
            _dotNetRef.Dispose();
            _dotNetRef = null;
        }
    }

    private void GoBack()
    {
        if (_session is not null)
            Nav.NavigateTo($"missions/infil/{_session.OperatorId}");
        else
            Nav.NavigateTo("operators");
    }

    public async ValueTask DisposeAsync()
    {
        await StopSseAsync();
    }
}
