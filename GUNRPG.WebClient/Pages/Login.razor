@page "/login"
@inject NodeConnectionService NodeService
@inject AuthService Auth
@inject ApiClient Api
@inject NavigationManager Nav
@inject IJSRuntime JS

<FluentCard Style="max-width: 480px; margin: 2rem auto; padding: 2rem;">
    <h2>Login</h2>

    <FluentTextField @bind-Value="_username"
                     Label="Username"
                     Placeholder="Enter your username"
                     Style="width: 100%;" />

    @if (!string.IsNullOrEmpty(_status))
    {
        <FluentMessageBar Title="Info" Intent="MessageIntent.Info" Style="margin-top: 0.5rem;">
            @_status
        </FluentMessageBar>
    }

    @if (!string.IsNullOrEmpty(_error))
    {
        <FluentMessageBar Title="Error" Intent="MessageIntent.Error" Style="margin-top: 0.5rem;">
            @_error
        </FluentMessageBar>
    }

    <FluentStack Orientation="Orientation.Horizontal" Style="margin-top: 1rem; gap: 0.5rem;">
        <FluentButton Appearance="Appearance.Accent"
                      OnClick="LoginAsync"
                      Disabled="_busy">
            Login with Passkey
        </FluentButton>

        <FluentButton Appearance="Appearance.Outline"
                      OnClick="RegisterAsync"
                      Disabled="_busy">
            Register Passkey
        </FluentButton>
    </FluentStack>
</FluentCard>

@code {
    private string _username = string.Empty;
    private string? _error;
    private string? _status;
    private bool _busy;

    protected override async Task OnInitializedAsync()
    {
        var baseUrl = await NodeService.GetBaseUrlAsync();
        if (string.IsNullOrEmpty(baseUrl))
            Nav.NavigateTo("/");
    }

    private async Task LoginAsync()
    {
        _error = null;
        _status = "Starting login...";
        _busy = true;
        StateHasChanged();

        try
        {
            var beginResponse = await Api.PostAsync("/auth/webauthn/login/begin",
                new { username = _username });

            if (!beginResponse.IsSuccessStatusCode)
            {
                _error = $"Login begin failed: {beginResponse.StatusCode}";
                return;
            }

            var optionsJson = await beginResponse.Content.ReadAsStringAsync();
            _status = "Waiting for passkey...";
            StateHasChanged();

            var assertionJson = await JS.InvokeAsync<string>("webauthn.startLogin", optionsJson);

            var completeResponse = await Api.PostAsync("/auth/webauthn/login/complete",
                new { username = _username, assertionResponseJson = assertionJson });

            if (!completeResponse.IsSuccessStatusCode)
            {
                _error = $"Login complete failed: {completeResponse.StatusCode}";
                return;
            }

            var tokens = await completeResponse.Content.ReadFromJsonAsync<TokenResponse>();
            if (tokens is null)
            {
                _error = "Invalid token response.";
                return;
            }

            await Auth.SetTokensAsync(tokens.AccessToken, tokens.RefreshToken);
            Nav.NavigateTo("/dashboard");
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
            _status = null;
        }
    }

    private async Task RegisterAsync()
    {
        _error = null;
        _status = "Starting registration...";
        _busy = true;
        StateHasChanged();

        try
        {
            var beginResponse = await Api.PostAsync("/auth/webauthn/register/begin",
                new { username = _username });

            if (!beginResponse.IsSuccessStatusCode)
            {
                _error = $"Register begin failed: {beginResponse.StatusCode}";
                return;
            }

            var optionsJson = await beginResponse.Content.ReadAsStringAsync();
            _status = "Waiting for passkey...";
            StateHasChanged();

            var attestationJson = await JS.InvokeAsync<string>("webauthn.startRegistration", optionsJson);

            var completeResponse = await Api.PostAsync("/auth/webauthn/register/complete",
                new { username = _username, attestationResponseJson = attestationJson });

            if (!completeResponse.IsSuccessStatusCode)
            {
                _error = $"Register complete failed: {completeResponse.StatusCode}";
                return;
            }

            var tokens = await completeResponse.Content.ReadFromJsonAsync<TokenResponse>();
            if (tokens is null)
            {
                _error = "Invalid token response.";
                return;
            }

            await Auth.SetTokensAsync(tokens.AccessToken, tokens.RefreshToken);
            Nav.NavigateTo("/dashboard");
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
            _status = null;
        }
    }
}
