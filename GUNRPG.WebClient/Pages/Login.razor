@page "/login"
@inject NodeConnectionService NodeService
@inject AuthService Auth
@inject ApiClient Api
@inject NavigationManager Nav
@inject IJSRuntime JS

<FluentCard Style="max-width: 480px; margin: 2rem auto; padding: 2rem;">
    <h2>Login</h2>
    <p>Use your registered passkey to sign in — no username required.</p>

    @if (!string.IsNullOrEmpty(_status))
    {
        <FluentMessageBar Title="Info" Intent="MessageIntent.Info" Style="margin-top: 0.5rem;">
            @_status
        </FluentMessageBar>
    }

    @if (!string.IsNullOrEmpty(_error))
    {
        <FluentMessageBar Title="Error" Intent="MessageIntent.Error" Style="margin-top: 0.5rem;">
            @_error
        </FluentMessageBar>
    }

    <FluentButton Appearance="Appearance.Accent"
                  OnClick="LoginAsync"
                  Disabled="_busy"
                  Style="margin-top: 1rem;">
        Login with Passkey
    </FluentButton>
</FluentCard>

<FluentCard Style="max-width: 480px; margin: 1rem auto; padding: 2rem;">
    <h2>Register</h2>
    <p>New here? Enter a username and register a passkey.</p>

    <FluentTextField @bind-Value="_username"
                     Label="Username"
                     Placeholder="Enter your username"
                     Style="width: 100%;" />

    @if (!string.IsNullOrEmpty(_registerStatus))
    {
        <FluentMessageBar Title="Info" Intent="MessageIntent.Info" Style="margin-top: 0.5rem;">
            @_registerStatus
        </FluentMessageBar>
    }

    @if (!string.IsNullOrEmpty(_registerError))
    {
        <FluentMessageBar Title="Error" Intent="MessageIntent.Error" Style="margin-top: 0.5rem;">
            @_registerError
        </FluentMessageBar>
    }

    <FluentButton Appearance="Appearance.Outline"
                  OnClick="RegisterAsync"
                  Disabled="_busy"
                  Style="margin-top: 1rem;">
        Register Passkey
    </FluentButton>
</FluentCard>

@code {
    private string _username = string.Empty;

    // Login state
    private string? _error;
    private string? _status;

    // Register state
    private string? _registerError;
    private string? _registerStatus;

    private bool _busy;

    protected override async Task OnInitializedAsync()
    {
        var baseUrl = await NodeService.GetBaseUrlAsync();
        if (string.IsNullOrEmpty(baseUrl))
            Nav.NavigateTo(Nav.BaseUri);
    }

    private async Task LoginAsync()
    {
        _error = null;
        _status = "Starting login...";
        _busy = true;
        StateHasChanged();

        try
        {
            var beginResponse = await Api.PostAsync("/auth/webauthn/login/discoverable/begin");

            if (!beginResponse.IsSuccessStatusCode)
            {
                _error = $"Login begin failed: {beginResponse.StatusCode}";
                return;
            }

            var beginData = await beginResponse.Content.ReadFromJsonAsync<DiscoverableBeginResponse>();
            if (beginData is null)
            {
                _error = "Invalid begin response.";
                return;
            }

            _status = "Waiting for passkey...";
            StateHasChanged();

            var assertionJson = await JS.InvokeAsync<string>("webauthn.startLogin", beginData.OptionsJson);

            var completeResponse = await Api.PostAsync("/auth/webauthn/login/discoverable/complete",
                new { sessionId = beginData.SessionId, assertionResponseJson = assertionJson });

            if (!completeResponse.IsSuccessStatusCode)
            {
                _error = $"Login complete failed: {completeResponse.StatusCode}";
                return;
            }

            var tokens = await completeResponse.Content.ReadFromJsonAsync<TokenResponse>();
            if (tokens is null)
            {
                _error = "Invalid token response.";
                return;
            }

            await Auth.SetTokensAsync(tokens.AccessToken, tokens.RefreshToken);
            Nav.NavigateTo("dashboard");
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
            _status = null;
        }
    }

    private async Task RegisterAsync()
    {
        _registerError = null;
        _registerStatus = "Starting registration...";
        _busy = true;
        StateHasChanged();

        try
        {
            var beginResponse = await Api.PostAsync("/auth/webauthn/register/begin",
                new { username = _username });

            if (!beginResponse.IsSuccessStatusCode)
            {
                _registerError = $"Register begin failed: {beginResponse.StatusCode}";
                return;
            }

            var optionsJson = await beginResponse.Content.ReadAsStringAsync();
            _registerStatus = "Waiting for passkey...";
            StateHasChanged();

            var attestationJson = await JS.InvokeAsync<string>("webauthn.startRegistration", optionsJson);

            var completeResponse = await Api.PostAsync("/auth/webauthn/register/complete",
                new { username = _username, attestationResponseJson = attestationJson });

            if (!completeResponse.IsSuccessStatusCode)
            {
                _registerError = $"Register complete failed: {completeResponse.StatusCode}";
                return;
            }

            var tokens = await completeResponse.Content.ReadFromJsonAsync<TokenResponse>();
            if (tokens is null)
            {
                _registerError = "Invalid token response.";
                return;
            }

            await Auth.SetTokensAsync(tokens.AccessToken, tokens.RefreshToken);
            Nav.NavigateTo("dashboard");
        }
        catch (Exception ex)
        {
            _registerError = ex.Message;
        }
        finally
        {
            _busy = false;
            _registerStatus = null;
        }
    }

    private sealed record DiscoverableBeginResponse(string SessionId, string OptionsJson);
}
