@page "/operators/{Id:guid}/perks"
@inject AuthService Auth
@inject NavigationManager Nav
@inject OperatorService OperatorSvc

<FluentStack Orientation="Orientation.Vertical" Style="gap: 1rem; max-width: 700px; margin: 0 auto;">
    <FluentStack Orientation="Orientation.Horizontal" Style="align-items: center; gap: 0.5rem;">
        <FluentButton Appearance="Appearance.Outline"
                      OnClick="@(() => Nav.NavigateTo($"operators/{Id}"))">
            ← Back
        </FluentButton>
        <h2 style="margin: 0;">Unlock Perk</h2>
    </FluentStack>

    @if (!string.IsNullOrEmpty(_error))
    {
        <FluentMessageBar Title="Error" Intent="MessageIntent.Error">@_error</FluentMessageBar>
    }

    @if (!string.IsNullOrEmpty(_info))
    {
        <FluentMessageBar Title="Success" Intent="MessageIntent.Success">@_info</FluentMessageBar>
    }

    @if (_loading)
    {
        <FluentProgressRing />
    }
    else if (_operator is not null)
    {
        <FluentCard>
            <FluentStack Orientation="Orientation.Vertical" Style="gap: 0.5rem;">
                <FluentLabel Typo="Typography.H5">@_operator.Name</FluentLabel>
                @if (_operator.UnlockedPerks.Count > 0)
                {
                    <div>
                        <FluentLabel>Unlocked Perks</FluentLabel>
                        <div>@string.Join(", ", _operator.UnlockedPerks)</div>
                    </div>
                }
                else
                {
                    <div>No perks unlocked yet.</div>
                }
            </FluentStack>
        </FluentCard>

        <FluentCard>
            <FluentLabel Typo="Typography.H5">Available Perks</FluentLabel>
            <FluentStack Orientation="Orientation.Vertical" Style="gap: 0.5rem; margin-top: 0.5rem;">
                @foreach (var perk in _availablePerks)
                {
                    var alreadyUnlocked = _operator.UnlockedPerks.Contains(perk);
                    <FluentButton Appearance="@(alreadyUnlocked ? Appearance.Accent : Appearance.Outline)"
                                  OnClick="@(() => UnlockPerkAsync(perk))"
                                  Disabled="_busy || alreadyUnlocked"
                                  Style="width: 100%; justify-content: flex-start;">
                        @perk @(alreadyUnlocked ? "(unlocked)" : "")
                    </FluentButton>
                }
            </FluentStack>
        </FluentCard>
    }
</FluentStack>

@code {
    [Parameter] public Guid Id { get; set; }

    private static readonly string[] _availablePerks = ["Iron Lungs", "Quick Draw", "Toughness", "Fast Reload", "Steady Aim"];

    private OperatorState? _operator;
    private bool _loading = true;
    private bool _busy;
    private string? _error;
    private string? _info;

    protected override async Task OnInitializedAsync()
    {
        if (!Auth.IsAuthenticated)
        {
            Nav.NavigateTo("login");
            return;
        }

        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;
        StateHasChanged();

        var (data, error) = await OperatorSvc.GetAsync(Id);
        _operator = data;
        _error = error;
        _loading = false;
    }

    private async Task UnlockPerkAsync(string perkName)
    {
        _error = null;
        _info = null;
        _busy = true;
        StateHasChanged();

        var (data, error) = await OperatorSvc.UnlockPerkAsync(Id, perkName);
        _busy = false;

        if (error is not null)
        {
            _error = error;
            StateHasChanged();
            return;
        }

        _operator = data ?? _operator;
        _info = $"Perk '{perkName}' unlocked successfully.";
        StateHasChanged();
    }
}
