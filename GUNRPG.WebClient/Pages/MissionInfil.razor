@page "/missions/infil/{OperatorId:guid}"
@inject AuthService Auth
@inject NavigationManager Nav
@inject OperatorService OperatorSvc
@inject NodeConnectionService NodeService
@inject IJSRuntime JS
@inject ConnectionStateService Connection
@implements IAsyncDisposable

<FluentStack Orientation="Orientation.Vertical" Style="gap: 1rem; max-width: 700px; margin: 0 auto;">
    <h2 style="margin: 0;">Infiltration</h2>

    @if (!string.IsNullOrEmpty(_error))
    {
        <FluentMessageBar Title="Error" Intent="MessageIntent.Error">@_error</FluentMessageBar>
    }

    @if (!Connection.IsOnline)
    {
        <FluentMessageBar Title="OFFLINE MODE" Intent="MessageIntent.Warning">Mission progress will sync when connection returns.</FluentMessageBar>
    }

    @if (!string.IsNullOrEmpty(_statusMessage))
    {
        <FluentMessageBar Title="Mission Status" Intent="@_statusIntent">@_statusMessage</FluentMessageBar>
    }

    @if (_loading)
    {
        <FluentProgressRing />
    }
    else if (_operator is not null)
    {
        <FluentCard>
            <FluentStack Orientation="Orientation.Vertical" Style="gap: 0.5rem;">
                <FluentLabel Typo="Typography.H4">@_operator.Name</FluentLabel>
                <FluentStack Orientation="Orientation.Horizontal" Style="gap: 2rem;">
                    <div>
                        <FluentLabel>Status</FluentLabel>
                        <div>@_operator.CurrentMode</div>
                    </div>
                    <div>
                        <FluentLabel>Health</FluentLabel>
                        <div>@_operator.CurrentHealth.ToString("F0") / @_operator.MaxHealth.ToString("F0")</div>
                    </div>
                </FluentStack>
                @if (_operator.InfilStartTime.HasValue)
                {
                    <div>
                        <FluentLabel>Infil started</FluentLabel>
                        <div>@_operator.InfilStartTime.Value.ToLocalTime().ToString("g")</div>
                    </div>
                    <div>
                        <FluentLabel>Exfil timer</FluentLabel>
                        <div style="@GetTimerStyle()">@FormatRemaining()</div>
                    </div>
                }
            </FluentStack>
        </FluentCard>

        <FluentStack Orientation="Orientation.Horizontal" Style="gap: 0.5rem; flex-wrap: wrap;">
            @if (_operator.ActiveCombatSessionId.HasValue && _operator.ActiveCombatSession?.IsConcluded == false)
            {
                <FluentButton Appearance="Appearance.Accent"
                              OnClick="@(() => Nav.NavigateTo($"missions/{_operator.ActiveCombatSessionId}?operatorId={OperatorId}"))">
                    Resume Combat
                </FluentButton>
            }
            else
            {
                <FluentButton Appearance="Appearance.Accent"
                              OnClick="StartNewCombatSessionAsync"
                              Disabled="_busy">
                    @(_busy ? "Starting..." : "Start Combat")
                </FluentButton>
            }

            <FluentButton Appearance="Appearance.Outline"
                          OnClick="ExfilAsync"
                          Disabled="_busy">
                @(_busy ? "Exfiling..." : "Exfil")
            </FluentButton>
        </FluentStack>
    }
</FluentStack>

@code {
    [Parameter] public Guid OperatorId { get; set; }

    private static readonly TimeSpan RaidDuration = TimeSpan.FromMinutes(30);

    private OperatorState? _operator;
    private bool _loading = true;
    private bool _busy;
    private string? _error;
    private string? _statusMessage;
    private MessageIntent _statusIntent = MessageIntent.Info;

    private PeriodicTimer? _countdownTimer;
    private CancellationTokenSource? _cts;
    private Task? _countdownTask;

    // SSE for real-time operator state sync
    private DotNetObjectReference<MissionInfil>? _dotNetRef;
    private string? _sseUrl;

    protected override async Task OnInitializedAsync()
    {
        if (!Auth.IsAuthenticated)
        {
            Nav.NavigateTo("login");
            return;
        }

        await LoadAsync();

        // Redirect guard: if operator is not in Infil mode, navigate to the correct screen
        if (_operator is not null)
        {
            if (_operator.CurrentMode == "Base")
            {
                if (!Connection.IsOnline)
        {
            _statusIntent = MessageIntent.Info;
            _statusMessage = "Exfil queued. Your mission will sync and validate when the connection returns.";
            StateHasChanged();
            return;
        }

        Nav.NavigateTo($"operators/{OperatorId}");
                return;
            }

            if (_operator.ActiveCombatSessionId.HasValue &&
                _operator.ActiveCombatSession?.IsConcluded == false)
            {
                Nav.NavigateTo($"missions/{_operator.ActiveCombatSessionId}?operatorId={OperatorId}");
                return;
            }
        }

        if (_operator?.InfilStartTime.HasValue == true)
            _countdownTask = RunCountdownAsync();

    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;
        StateHasChanged();

        var (data, error) = await OperatorSvc.GetAsync(OperatorId);
        _operator = data;
        _error = error;
        _loading = false;
    }

    private async Task StartSseAsync()
    {
        var baseUrl = await NodeService.GetBaseUrlAsync();
        if (!AuthenticatedSseHelper.TryGetHttpsBaseUrl(baseUrl, out var httpsBaseUrl))
            return;

        _sseUrl = $"{httpsBaseUrl}/operators/{OperatorId}/stream";
        _dotNetRef = DotNetObjectReference.Create(this);
        await JS.InvokeVoidAsync("sseHelper.connect", _sseUrl, _dotNetRef, nameof(OnOperatorUpdated), nameof(GetSseAccessTokenAsync));
    }

    [JSInvokable]
    public async Task OnOperatorUpdated()
    {
        var (data, _) = await OperatorSvc.GetAsync(OperatorId);
        if (data is null) return;

        _operator = data;

        // Redirect guard: if operator is no longer in Infil mode
        if (_operator.CurrentMode == "Base")
        {
            await InvokeAsync(() => Nav.NavigateTo($"operators/{OperatorId}"));
            return;
        }

        // Navigate to combat when another client starts a session
        if (_operator.ActiveCombatSessionId.HasValue &&
            _operator.ActiveCombatSession?.IsConcluded == false)
        {
            await InvokeAsync(() => Nav.NavigateTo($"missions/{_operator.ActiveCombatSessionId}?operatorId={OperatorId}"));
            return;
        }

        await InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public Task<string?> GetSseAccessTokenAsync(bool forceRefresh) => Auth.GetSseAccessTokenAsync(forceRefresh);

    private async Task StopSseAsync()
    {
        if (!string.IsNullOrEmpty(_sseUrl))
        {
            try
            {
                await JS.InvokeVoidAsync("sseHelper.disconnect", _sseUrl);
            }
            catch
            {
                // Ignore JS interop errors during cleanup
            }
        }

        _sseUrl = null;

        if (_dotNetRef is not null)
        {
            _dotNetRef.Dispose();
            _dotNetRef = null;
        }
    }

    private TimeSpan? GetRemaining() =>
        ExfilCountdownHelper.GetRemaining(_operator?.InfilStartTime, RaidDuration);

    private string FormatRemaining() =>
        ExfilCountdownHelper.FormatRemaining(GetRemaining());

    private string GetTimerStyle() =>
        ExfilCountdownHelper.GetTimerStyle(GetRemaining());

    private async Task RunCountdownAsync()
    {
        _cts = new CancellationTokenSource();
        _countdownTimer = new PeriodicTimer(TimeSpan.FromSeconds(1));
        try
        {
            while (await _countdownTimer.WaitForNextTickAsync(_cts.Token))
            {
                var remaining = GetRemaining();
                await InvokeAsync(StateHasChanged);
                if (remaining.HasValue && remaining.Value <= TimeSpan.Zero)
                {
                    await InvokeAsync(() => Nav.NavigateTo($"missions/exfil-failed/{OperatorId}"));
                    break;
                }
            }
        }
        catch (Exception ex) when (ex is OperationCanceledException || ex is ObjectDisposedException) { }
    }

    private async Task StartNewCombatSessionAsync()
    {
        if (_operator is null) return;

        _error = null;
        _busy = true;
        StateHasChanged();

        var (sessionId, error) = await OperatorSvc.StartCombatSessionAsync(OperatorId);
        _busy = false;

        if (error is not null)
        {
            _error = error;
            StateHasChanged();
            return;
        }

        if (sessionId.HasValue && sessionId.Value != Guid.Empty)
            Nav.NavigateTo($"missions/{sessionId.Value}?operatorId={OperatorId}");
    }

    private async Task ExfilAsync()
    {
        _error = null;
        _statusMessage = null;
        _busy = true;
        StateHasChanged();

        var error = await OperatorSvc.CompleteInfilAsync(OperatorId);
        _busy = false;

        if (error is not null)
        {
            _error = error;
            StateHasChanged();
            return;
        }

        if (!Connection.IsOnline)
        {
            _statusIntent = MessageIntent.Info;
            _statusMessage = "Exfil queued. Your mission will sync and validate when the connection returns.";
            StateHasChanged();
            return;
        }

        Nav.NavigateTo($"operators/{OperatorId}");
    }

    public async ValueTask DisposeAsync()
    {
        _cts?.Cancel();
        if (_countdownTask is not null)
            await _countdownTask;
        _countdownTimer?.Dispose();
        _cts?.Dispose();
        await StopSseAsync();
    }
}
