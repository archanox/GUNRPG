@page "/operators/{Id:guid}/loadout"
@inject AuthService Auth
@inject NavigationManager Nav
@inject OperatorService OperatorSvc

<FluentStack Orientation="Orientation.Vertical" Style="gap: 1rem; max-width: 700px; margin: 0 auto;">
    <FluentStack Orientation="Orientation.Horizontal" Style="align-items: center; gap: 0.5rem;">
        <FluentButton Appearance="Appearance.Outline"
                      OnClick="@(() => Nav.NavigateTo($"operators/{Id}"))">
            ← Back
        </FluentButton>
        <h2 style="margin: 0;">Change Loadout</h2>
    </FluentStack>

    @if (!string.IsNullOrEmpty(_error))
    {
        <FluentMessageBar Title="Error" Intent="MessageIntent.Error">@_error</FluentMessageBar>
    }

    @if (!string.IsNullOrEmpty(_info))
    {
        <FluentMessageBar Title="Success" Intent="MessageIntent.Success">@_info</FluentMessageBar>
    }

    @if (_loading)
    {
        <FluentProgressRing />
    }
    else if (_operator is not null)
    {
        <FluentCard>
            <FluentStack Orientation="Orientation.Vertical" Style="gap: 0.5rem;">
                <FluentLabel Typo="Typography.H5">@_operator.Name</FluentLabel>
                <div>
                    <FluentLabel>Current Weapon</FluentLabel>
                    <div>@_operator.EquippedWeaponName</div>
                </div>
            </FluentStack>
        </FluentCard>

        <FluentCard>
            <FluentLabel Typo="Typography.H5">Available Weapons</FluentLabel>
            <FluentStack Orientation="Orientation.Vertical" Style="gap: 0.5rem; margin-top: 0.5rem;">
                @foreach (var weapon in _availableWeapons)
                {
                    <FluentButton Appearance="@(_operator.EquippedWeaponName == weapon ? Appearance.Accent : Appearance.Outline)"
                                  OnClick="@(() => ChangeLoadoutAsync(weapon))"
                                  Disabled="_busy || _operator.EquippedWeaponName == weapon"
                                  Style="width: 100%; justify-content: flex-start;">
                        @weapon @(_operator.EquippedWeaponName == weapon ? "(equipped)" : "")
                    </FluentButton>
                }
            </FluentStack>
        </FluentCard>
    }
</FluentStack>

@code {
    [Parameter] public Guid Id { get; set; }

    private static readonly string[] _availableWeapons = ["SOKOL 545", "STURMWOLF 45", "M15 MOD 0"];

    private OperatorState? _operator;
    private bool _loading = true;
    private bool _busy;
    private string? _error;
    private string? _info;

    protected override async Task OnInitializedAsync()
    {
        if (!Auth.IsAuthenticated)
        {
            Nav.NavigateTo("login");
            return;
        }

        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;
        StateHasChanged();

        var (data, error) = await OperatorSvc.GetAsync(Id);
        _operator = data;
        _error = error;
        _loading = false;
    }

    private async Task ChangeLoadoutAsync(string weaponName)
    {
        _error = null;
        _info = null;
        _busy = true;
        StateHasChanged();

        var (data, error) = await OperatorSvc.ChangeLoadoutAsync(Id, weaponName);
        _busy = false;

        if (error is not null)
        {
            _error = error;
            StateHasChanged();
            return;
        }

        _operator = data ?? _operator;
        _info = $"Loadout changed to {weaponName}.";
        StateHasChanged();
    }
}
