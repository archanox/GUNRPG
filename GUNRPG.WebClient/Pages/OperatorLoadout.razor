@page "/operators/{Id:guid}/loadout"
@inject AuthService Auth
@inject NavigationManager Nav
@inject OperatorService OperatorSvc
@inject NodeConnectionService NodeService
@inject IJSRuntime JS
@implements IAsyncDisposable

<FluentStack Orientation="Orientation.Vertical" Style="gap: 1rem; max-width: 700px; margin: 0 auto;">
    <FluentStack Orientation="Orientation.Horizontal" Style="align-items: center; gap: 0.5rem;">
        <FluentButton Appearance="Appearance.Outline"
                      OnClick="@(() => Nav.NavigateTo($"operators/{Id}"))">
            ← Back
        </FluentButton>
        <h2 style="margin: 0;">Change Loadout</h2>
    </FluentStack>

    @if (!string.IsNullOrEmpty(_error))
    {
        <FluentMessageBar Title="Error" Intent="MessageIntent.Error">@_error</FluentMessageBar>
    }

    @if (!string.IsNullOrEmpty(_info))
    {
        <FluentMessageBar Title="Success" Intent="MessageIntent.Success">@_info</FluentMessageBar>
    }

    @if (_loading)
    {
        <FluentProgressRing />
    }
    else if (_operator is not null)
    {
        <FluentCard>
            <FluentStack Orientation="Orientation.Vertical" Style="gap: 0.5rem;">
                <FluentLabel Typo="Typography.H5">@_operator.Name</FluentLabel>
                <div>
                    <FluentLabel>Current Weapon</FluentLabel>
                    <div>@_operator.EquippedWeaponName</div>
                </div>
            </FluentStack>
        </FluentCard>

        <FluentCard>
            <FluentLabel Typo="Typography.H5">Available Weapons</FluentLabel>
            <FluentStack Orientation="Orientation.Vertical" Style="gap: 1rem; margin-top: 0.5rem;">
                @foreach (var weapon in _availableWeapons)
                {
                    var stats = _weaponStatsByName.GetValueOrDefault(weapon);
                    var isEquipped = _operator.EquippedWeaponName == weapon;
                    <FluentCard Style="@(isEquipped ? "border: 2px solid var(--accent-fill-rest);" : "")">
                        <FluentStack Orientation="Orientation.Vertical" Style="gap: 0.5rem;">
                            <FluentStack Orientation="Orientation.Horizontal" Style="align-items: center; justify-content: space-between;">
                                <FluentLabel Typo="Typography.H6" Style="margin: 0;">
                                    @weapon @(isEquipped ? " ✓ Equipped" : "")
                                </FluentLabel>
                                <FluentButton Appearance="@(isEquipped ? Appearance.Accent : Appearance.Outline)"
                                              OnClick="@(() => ChangeLoadoutAsync(weapon))"
                                              Disabled="_busy || isEquipped">
                                    @(isEquipped ? "Equipped" : "Equip")
                                </FluentButton>
                            </FluentStack>

                            @if (stats is not null)
                            {
                                <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 0.25rem 1rem; font-size: 0.85rem;">
                                    <div><strong>Fire Rate:</strong> @stats.RoundsPerMinute RPM</div>
                                    <div><strong>Bullet Velocity:</strong> @stats.BulletVelocityMetersPerSecond.ToString("F0") m/s</div>
                                    <div><strong>Magazine:</strong> @stats.MagazineSize rds</div>
                                    <div><strong>Reload:</strong> @((stats.ReloadTimeMs / 1000f).ToString("F2"))s</div>
                                    <div><strong>ADS Time:</strong> @stats.ADSTimeMs ms</div>
                                    <div><strong>Sprint-to-Fire:</strong> @stats.SprintToFireTimeMs.ToString("F0") ms</div>
                                    <div><strong>Hipfire Spread:</strong> @stats.HipfireSpreadDegrees.ToString("F2")°</div>
                                    <div><strong>ADS Spread:</strong> @stats.ADSSpreadDegrees.ToString("F2")°</div>
                                    <div><strong>V. Recoil:</strong> @stats.VerticalRecoil.ToString("F4")</div>
                                    <div><strong>H. Recoil:</strong> @stats.HorizontalRecoil.ToString("F4")</div>
                                    <div><strong>Flinch Resist:</strong> @((stats.FlinchResistance * 100).ToString("F0"))%</div>
                                    <div><strong>Suppression:</strong> @stats.SuppressionFactor.ToString("F1")×</div>
                                    <div><strong>Move Speed:</strong> @stats.MovementSpeedMetersPerSecond.ToString("F1") m/s</div>
                                    <div><strong>Sprint Speed:</strong> @stats.SprintingMovementSpeedMetersPerSecond.ToString("F1") m/s</div>
                                    <div><strong>ADS Move Speed:</strong> @stats.ADSMovementSpeedMetersPerSecond.ToString("F1") m/s</div>
                                    <div><strong>Headshot Mult:</strong> @stats.HeadshotMultiplier.ToString("F1")×</div>
                                </div>

                                @if (stats.DamageRanges.Count > 0)
                                {
                                    <div>
                                        <strong style="font-size: 0.85rem;">Damage by Range:</strong>
                                        <div style="display: flex; flex-wrap: wrap; gap: 0.25rem 0.75rem; font-size: 0.8rem; margin-top: 0.2rem;">
                                            @foreach (var range in stats.DamageRanges)
                                            {
                                                var maxLabel = float.IsPositiveInfinity(range.MaxMeters) ? "∞" : range.MaxMeters.ToString("F0");
                                                <span>@range.MinMeters.ToString("F0")–@(maxLabel)m: <strong>@range.Damage.ToString("F0")</strong> (@range.HeadDamage.ToString("F0") head)</span>
                                            }
                                        </div>
                                    </div>
                                }
                            }
                        </FluentStack>
                    </FluentCard>
                }
            </FluentStack>
        </FluentCard>
    }
</FluentStack>

@code {
    [Parameter] public Guid Id { get; set; }

    private static readonly string[] _availableWeapons = ["SOKOL 545", "STURMWOLF 45", "M15 MOD 0"];

    private OperatorState? _operator;
    private Dictionary<string, WeaponStats> _weaponStatsByName = new();
    private bool _loading = true;
    private bool _busy;
    private string? _error;
    private string? _info;
    private DotNetObjectReference<OperatorLoadout>? _dotNetRef;
    private string? _sseUrl;

    protected override async Task OnInitializedAsync()
    {
        if (!Auth.IsAuthenticated)
        {
            Nav.NavigateTo("login");
            return;
        }

        await Task.WhenAll(LoadAsync(), LoadWeaponStatsAsync());

        if (await TryNavigateToRealtimeRouteAsync())
            return;

        await StartSseAsync();
    }

    private async Task LoadAsync()
    {
        _loading = true;
        _error = null;
        StateHasChanged();

        var (data, error) = await OperatorSvc.GetAsync(Id);
        _operator = data;
        _error = error;
        _loading = false;
    }

    private async Task LoadWeaponStatsAsync()
    {
        var (data, error) = await OperatorSvc.GetWeaponsAsync();
        if (data is not null)
            _weaponStatsByName = data.ToDictionary(w => w.Name, StringComparer.OrdinalIgnoreCase);
        else if (error is not null)
            _error = $"Failed to load weapon stats: {error}";
    }

    private async Task StartSseAsync()
    {
        var baseUrl = await NodeService.GetBaseUrlAsync();
        if (!AuthenticatedSseHelper.TryGetHttpsBaseUrl(baseUrl, out var httpsBaseUrl))
            return;

        _sseUrl = $"{httpsBaseUrl}/operators/{Id}/stream";
        _dotNetRef = DotNetObjectReference.Create(this);
        await JS.InvokeVoidAsync("sseHelper.connect", _sseUrl, _dotNetRef, nameof(OnOperatorUpdated), nameof(GetSseAccessTokenAsync));
    }

    [JSInvokable]
    public async Task OnOperatorUpdated()
    {
        var (data, _) = await OperatorSvc.GetAsync(Id);
        if (data is null)
            return;

        _operator = data;
        _info = null;

        if (await TryNavigateToRealtimeRouteAsync())
            return;

        await InvokeAsync(StateHasChanged);
    }

    private Task<bool> TryNavigateToRealtimeRouteAsync()
    {
        var route = OperatorNavigationHelper.GetRealtimeRoute(_operator, Id);
        if (string.IsNullOrEmpty(route))
            return Task.FromResult(false);

        return NavigateToRealtimeRouteAsync(route);
    }

    private async Task<bool> NavigateToRealtimeRouteAsync(string route)
    {
        await InvokeAsync(() => Nav.NavigateTo(route));
        return true;
    }

    [JSInvokable]
    public Task<string?> GetSseAccessTokenAsync(bool forceRefresh) => Auth.GetSseAccessTokenAsync(forceRefresh);

    private async Task ChangeLoadoutAsync(string weaponName)
    {
        _error = null;
        _info = null;
        _busy = true;
        StateHasChanged();

        var (data, error) = await OperatorSvc.ChangeLoadoutAsync(Id, weaponName);
        _busy = false;

        if (error is not null)
        {
            _error = error;
            StateHasChanged();
            return;
        }

        _operator = data ?? _operator;
        _info = $"Loadout changed to {weaponName}.";
        StateHasChanged();
    }

    private async Task StopSseAsync()
    {
        if (!string.IsNullOrEmpty(_sseUrl))
        {
            try
            {
                await JS.InvokeVoidAsync("sseHelper.disconnect", _sseUrl);
            }
            catch
            {
                // Ignore JS interop errors during cleanup
            }
        }

        _sseUrl = null;

        if (_dotNetRef is not null)
        {
            _dotNetRef.Dispose();
            _dotNetRef = null;
        }
    }

    public async ValueTask DisposeAsync()
    {
        await StopSseAsync();
    }
}
