{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Storage": {
    "Provider": "LiteDB",
    "LiteDbConnectionString": "combat_sessions.db"
  },
  "Jwt": {
    "Issuer": "gunrpg",
    "Audience": "gunrpg",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 30
  },
  "WebAuthn": {
    "ServerDomain": "localhost",
    "ServerName": "GunRPG",
    "Origins": [ "https://localhost", "http://localhost" ]
  }
}
